# Copy to data/.env and adjust. On first run the server will generate missing
# secrets into data/.env. All data files (SQLite db + .env) live in the data dir.
#
# Directory holding the database and .env (default: ./data). Created if missing.
WEBSSH_DATA_DIR=data

# Address the HTTP server binds to.
WEBSSH_HOST=127.0.0.1
WEBSSH_PORT=3000

# Sub-path to serve the app under, e.g. "/webssh". Empty = root deployment.
# The app, /api, and /healthz all move under this prefix; a bare "/" redirects
# to "{context_path}/" for convenience. Environment variable overrides this file.
WEBSSH_CONTEXT_PATH=

# Path to the SQLite database file (default: ./data/webssh.db).
WEBSSH_DATABASE_URL=sqlite://data/webssh.db?mode=rwc

# 32-byte (64 hex char / 44 base64 char) master key used to encrypt SSH
# credentials at rest. Leave empty on first run to auto-generate into .env.
WEBSSH_MASTER_KEY=

# Secret used to sign session cookies. Leave empty on first run to auto-generate.
WEBSSH_SESSION_KEY=

# Session cookie lifetime in seconds (default 7 days).
WEBSSH_SESSION_TTL_SECS=604800

# Terminal idle timeout in seconds (default 0 = never disconnect on idle).
# When > 0, a terminal session with no traffic for this long is closed.
# A keepalive heartbeat runs regardless (every 30s) to keep connections alive
# against NAT/proxy/ssh-sshd idle killers.
WEBSSH_TERMINAL_IDLE_TIMEOUT_SECS=0
